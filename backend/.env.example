# ============================================
# BACKEND ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# ============================================

# Database (PostgreSQL with pgvector)
# Setup: createdb ai_career_dev
# Then: psql ai_career_dev -c "CREATE EXTENSION IF NOT EXISTS vector;"
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/ai_career_dev

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# AI / LLM (Free - get from https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here

# File Storage (get from https://supabase.com)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_BUCKET=resumes

# Email (OPTIONAL - app works without this)
# Get free account from https://mailtrap.io
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USERNAME=your-mailtrap-username
SMTP_PASSWORD=your-mailtrap-password

# App Settings
FRONTEND_URL=http://localhost:5173
RATE_LIMIT_ENABLED=false
LOG_LEVEL=DEBUG